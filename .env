# Hedera Testnet
HEDERA_NETWORK=testnet
HEDERA_JSON_RPC=https://testnet.hashio.io/api
HEDERA_MIRROR_NODE=https://testnet.mirrornode.hedera.com
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=wc_project_id_here

# -----------------------------------------------------
# ACTION REQUIRED: Hedera Operator Credentials
# To get these:
# 1. Go to https://portal.hedera.com/
# 2. Sign in or create an account
# 3. Your "Testnet Account ID" goes in HEDERA_OPERATOR_ID (e.g., 0.0.xxxxx)
# 4. Your "Testnet DER Encoded Private Key" goes in HEDERA_OPERATOR_KEY
# 5. Your "Testnet ECDSA Private Key" goes in DEPLOYER_PRIVATE_KEY
#    (It usually starts with 0x. If you don't have one on portal, you can generate a new EVM wallet like MetaMask and use that hex key for DEPLOYER_PRIVATE_KEY, but it must be funded with testnet HBAR)
# -----------------------------------------------------
HEDERA_OPERATOR_ID=0.0.8127508
HEDERA_OPERATOR_KEY=0xeef687f1d869920959c4b21076c587c69cc42c47658ea1ccee7b5bfb87d169bd
DEPLOYER_PRIVATE_KEY=0xeef687f1d869920959c4b21076c587c69cc42c47658ea1ccee7b5bfb87d169bd

# -----------------------------------------------------
# ACTION REQUIRED: Google Gemini API Key
# To get this (Free):
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API Key"
# -----------------------------------------------------
GEMINI_API_KEY=AIzaSyDWlfFaQnf8FPQo5I7GMDOPSa5Uq6EEzNU

# Optional: Price Data (Free Tier CoinGecko is fine, or leave blank to fallback)
COINGECKO_API_KEY=

