{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/discourse/layout,_N_T_/discourse/page,_N_T_/discourse"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/discourse/__PAGE__",
    "/discourse",
    "/_index",
    "/_head"
  ]
}